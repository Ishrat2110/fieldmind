# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:////path/to/farm_manager.db

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# If unset, reorder suggestions fall back to rule-based logic (no AI calls)
GEMINI_API_KEY=

# ── Reorder AI tuning (optional) ──────────────────────────────────────────────
REORDER_AI_CACHE_HOURS=24          # hours before a new suggestion is generated for the same item
REORDER_AI_DEFAULT_LEAD_DAYS=7     # assumed supplier lead time (days) used by rule-based fallback
REORDER_AI_MAX_QTY_MULTIPLIER=5    # safety cap: AI cannot suggest more than N × reorder_quantity
